-D hscript-iris=1.1.3
-cp D:/code/Impostor-Split/.haxelib/hxdiscord_rpc/1,2,4
-D hxdiscord_rpc=1.2.4
-cp D:/code/Impostor-Split/.haxelib/hxcpp/4,3,2
-D hxcpp=4.3.2
-cp D:/code/Impostor-Split/.haxelib/flxanimate/git
-D flxanimate=4.0.0
