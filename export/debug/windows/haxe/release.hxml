--macro openfl.utils._internal.ExtraParamsMacro.include()
-cp D:/code/Impostor-Split/.haxelib/openfl/9,3,3/src
-D openfl=9.3.3
-D lime=8.1.2
-cp D:\code\Impostor-Split\.haxelib\lime\8,1,2/src
--macro keep('IntIterator')
-cp D:/code/Impostor-Split/.haxelib/hscript/2,6,0
-D hscript=2.6.0
